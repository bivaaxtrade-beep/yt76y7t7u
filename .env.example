# Environment Variables Example

# Gemini API Key (Required for AI features)
GEMINI_API_KEY=

# Financial Modeling Prep API Key (Required for live market data)
FMP_API_KEY=

# Firebase Configuration (Automatically injected by platform)
# FIREBASE_SERVICE_ACCOUNT=

# Email Service (Optional)
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Database Configuration (MySQL)
# Set these for your Ubuntu VPS deployment
SQL_HOST=localhost
SQL_DB_NAME=bivaax_trade
SQL_USER=bivaax_user
SQL_PASSWORD=your_secure_password
SQL_ADMIN_USER=root
SQL_ADMIN_PASSWORD=root_password


# Authentication (Google OAuth)
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Add this Redirect URI: https://ais-dev-xze6kl4beokvjabfc2s6fr-883171138138.asia-east1.run.app/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=bivax_super_secret_local_key
APP_URL=https://ais-dev-xze6kl4beokvjabfc2s6fr-883171138138.asia-east1.run.app
