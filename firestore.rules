rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Market candles: Read-only for authenticated users
    match /market_candles/{candleId} {
      allow read: if request.auth != null;
      allow write: if false; // Only server-side via Admin SDK
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Existing collections from the app (e.g., tickets, kyc, etc.)
    match /tickets/{ticketId} {
      allow read, write: if request.auth != null;
    }
    
    match /kyc_requests/{requestId} {
      allow read, write: if request.auth != null;
    }
  }
}
